# Copy to .env locally, or paste into Render → Environment → "Add from .env"
# Replace every placeholder. Do not commit a filled .env file.

# --- Required (must be the FULL URI starting with mysql://, not an id or password alone) ---
DATABASE_URL=mysql://USER:PASSWORD@HOST:3306/DATABASE_NAME

# Your Vercel site (comma-separated for multiple, no spaces after commas)
CORS_ORIGIN=https://college-management-system-cms-gamma.vercel.app

# --- Firebase Admin (pick ONE approach) ---

# Option A: Entire service account JSON on ONE line (escape inner quotes if needed)
# FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"...","private_key_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","client_email":"...","client_id":"..."}

# Option B: Split variables (common on Render). Use \n in the private key string.
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project-id.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\nYOUR_KEY_LINES_HERE\n-----END PRIVATE KEY-----\n

# --- Optional (defaults exist in code for Cloudinary; set in production) ---
NODE_ENV=production
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
SENDGRID_API_KEY=
EMAIL_FROM=no-reply@yourdomain.com

# PORT is set automatically on Render; omit or match your platform.
