# =============================================================================
# RENDER (Web Service) OR local backend/.env — "Add from .env" on Render: paste
# only lines you have filled; remove empty optional lines.
# =============================================================================

# --- Required ---
# Aiven: Dashboard → Service → Connection → copy "Service URI" exactly (mysql://...)
# Do not use placeholders like @HOST: — the hostname must be real.
DATABASE_URL=

# Vercel frontend origin(s). Comma-separated, no spaces after commas.
CORS_ORIGIN=https://college-management-system-cms-gamma.vercel.app

# --- Strongly recommended (otherwise Firebase auth is demo / insecure) ---
# Option A: one-line JSON from Firebase service account key file
# FIREBASE_SERVICE_ACCOUNT=

# Option B: split (Render-friendly). Private key: one line with \n for newlines
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# --- Optional ---
NODE_ENV=production
SENDGRID_API_KEY=
EMAIL_FROM=
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# PORT is set by Render automatically.
