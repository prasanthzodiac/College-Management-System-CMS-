# =============================================================================
# TWO PLATFORMS — use the right block in the right dashboard.
#
#   [A] RENDER → your Node Web Service → Environment → "Add from .env"
#       Only use section [RENDER_BACKEND] (no VITE_ lines).
#
#   [B] VERCEL → your frontend project → Environment
#       Only use section [VERCEL_FRONTEND] (no DATABASE_URL here).
#
# Check backend locally: cd backend && npm run check-env
# =============================================================================

# --- [RENDER_BACKEND] copy from here down to ---END_RENDER---
DATABASE_URL=
CORS_ORIGIN=https://college-management-system-cms-gamma.vercel.app
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
NODE_ENV=production
# ---END_RENDER---

# --- [VERCEL_FRONTEND] add these in Vercel only ---
# VITE_API_BASE_URL=https://your-api.onrender.com
# VITE_FIREBASE_API_KEY=
# VITE_FIREBASE_AUTH_DOMAIN=
# VITE_FIREBASE_PROJECT_ID=
# VITE_FIREBASE_APP_ID=
# ---END_VERCEL---
